{
  "openapi": "3.0.3",
  "info": {
    "title": "Policies REST API",
    "version": "1.0.0",
    "description": "Mock policies service. Source of truth for the Policy model consumed by the GraphQL schema generator (schema-gen/generate.mjs)."
  },
  "paths": {
    "/policies": {
      "get": {
        "summary": "List policies",
        "responses": {
          "200": {
            "description": "A list of policies",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Policy" } }
              }
            }
          }
        }
      }
    },
    "/policies/{id}": {
      "get": {
        "summary": "Get policy by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "example": "pol-life-3001" }
        ],
        "responses": {
          "200": {
            "description": "The requested policy",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Policy" }
              }
            }
          },
          "404": {
            "description": "Policy not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/accounts/{accountId}/policies": {
      "get": {
        "summary": "List policies for an account",
        "parameters": [
          { "name": "accountId", "in": "path", "required": true, "schema": { "type": "string" }, "example": "acct-1001" }
        ],
        "responses": {
          "200": {
            "description": "Policies attached to the account",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Policy" } }
              }
            }
          }
        }
      }
    },
    "/funds/{fundId}/policies": {
      "get": {
        "summary": "List policies linked to a fund",
        "parameters": [
          { "name": "fundId", "in": "path", "required": true, "schema": { "type": "string" }, "example": "fund-global-equity" }
        ],
        "responses": {
          "200": {
            "description": "Policies that invest in the fund",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Policy" } }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": { "type": "apiKey", "in": "header", "name": "X-Api-Key" }
    },
    "schemas": {
      "Policy": {
        "type": "object",
        "required": [
          "id",
          "policyNumber",
          "accountId",
          "customerId",
          "policyType",
          "productName",
          "status",
          "startDate",
          "premiumMonthly",
          "sumAssured",
          "insuredPerson",
          "fundIds"
        ],
        "properties": {
          "id": { "type": "string", "example": "pol-life-3001" },
          "policyNumber": { "type": "string", "example": "LIF-UK-3001" },
          "accountId": { "type": "string", "example": "acct-1001" },
          "customerId": { "type": "string", "example": "cust-501" },
          "policyType": {
            "type": "string",
            "enum": ["LIFE_INSURANCE", "PENSION_ANNUITY", "INVESTMENT_BOND"],
            "example": "LIFE_INSURANCE"
          },
          "productName": { "type": "string", "example": "Family Life Protect" },
          "status": { "type": "string", "enum": ["IN_FORCE", "ACCUMULATING"], "example": "IN_FORCE" },
          "startDate": { "type": "string", "format": "date", "example": "2018-06-01" },
          "premiumMonthly": { "type": "number", "example": 42.5 },
          "sumAssured": { "type": "number", "description": "0 when not applicable", "example": 450000 },
          "insuredPerson": { "type": "string", "example": "Anika Rao" },
          "fundIds": {
            "type": "array",
            "description": "Ids of funds the policy invests in; empty when none",
            "items": { "type": "string" },
            "example": ["fund-global-equity", "fund-green-bond"]
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string", "example": "Not found" }
        }
      }
    }
  }
}
