ACCOUNTS_API_KEY=accounts-local-key
POLICIES_API_KEY=policies-local-key
FUNDS_API_KEY=funds-local-key

# Subgraph-level Valkey cache (persistent, no Enterprise license needed).
# Set in docker-compose.yml per subgraph; override here to point at an external Redis/Valkey.
CACHE_URL=redis://valkey:6379

# Per-service TTL defaults are set directly in docker-compose.yml:
#   accounts → 120s  (account data changes infrequently)
#   policies → 30s   (policy status can change)
#   funds    → 300s  (fund prices update daily)

COUNTRIES_BASE_URL=http://localhost:3004